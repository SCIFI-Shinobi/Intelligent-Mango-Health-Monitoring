# ─────────────────────────────────────────────
# MangoGuard Backend — Environment Variables
# Copy this file to .env and fill in your values
# cp backend/.env.example backend/.env
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# PostgreSQL connection string
# Docker Compose default: postgresql://postgres:postgres@db:5432/plant_health
DATABASE_URL=postgresql://postgres:postgres@db:5432/plant_health

# ── Authentication ────────────────────────────
# JWT signing secret — use a long, random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret-key

# Default admin account created on first startup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# ── Supabase (Image Storage) ──────────────────
# Required for leaf image uploads and cloud scan history
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# ── Brevo (Email Alerts) ──────────────────────
# Required for disease detection and forecast email alerts
# Sign up at https://www.brevo.com and create an API key
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=alerts@yourdomain.com

# ── Performance Tuning (Optional) ────────────
# Log a warning for requests slower than this threshold (milliseconds)
REQUEST_SLOW_MS=800

# Suppress duplicate alert emails within this window (minutes, 0 = disabled)
NOTIFICATION_DEDUPE_MINUTES=0
